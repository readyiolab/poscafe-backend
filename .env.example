# Server
PORT=7000
NODE_ENV=development

# MySQL
DB_HOST=localhost
DB_USER=root
DB_PASS=your_mysql_password
DB_NAME=cafe_pos

# Auth — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_long_random_secret
JWT_EXPIRES_IN=1d

# CORS — your frontend URL (no trailing slash)
# Development: http://localhost:5173
# Production:  https://pos.yourdomain.com
FRONTEND_URL=http://localhost:5173

# Cloudinary (menu images) — optional but recommended
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Only for local `npm run seed` — NEVER use in production
# SEED_ADMIN_USERNAME=admin@example.com
# SEED_ADMIN_PASSWORD=change_me_before_seeding
